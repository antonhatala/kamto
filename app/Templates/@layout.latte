<!DOCTYPE html>
<html lang="cs">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{block title}Kamto{/block}</title>
	<link rel="stylesheet" href="/css/app.css">
</head>
<body class="min-h-dvh bg-stone-50 font-sans text-stone-900 antialiased">
{if $user->isLoggedIn()}
	{* Chrome přihlášené aplikace: hlavička s navigací + centralizované flash zprávy.
	   Sign/in si obsah (včetně flashů uvnitř karty) vykresluje celý sám — viz else větev. *}
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex max-w-3xl items-center gap-2 px-4 py-3 sm:px-6">
			<a n:href="Home:default" class="flex items-center gap-2.5 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent-200">
				<span class="flex h-8 w-8 items-center justify-center rounded-xl bg-accent-600 text-sm font-semibold text-white" aria-hidden="true">K</span>
				<span class="hidden text-base font-semibold tracking-tight text-stone-900 sm:inline">Kamto</span>
			</a>
			<nav aria-label="Hlavní navigace" class="ml-1 flex items-center gap-1 sm:ml-4">
				<a n:href="Service:default"
					n:class="'rounded-lg px-3 py-1.5 text-sm font-medium transition focus:outline-none focus:ring-2 focus:ring-accent-200', $presenter->isLinkCurrent('Service:*') ? 'bg-stone-100 text-stone-900' : 'text-stone-500 hover:bg-stone-50 hover:text-stone-900'"
				>Služby</a>
				<a n:href="Category:default"
					n:class="'rounded-lg px-3 py-1.5 text-sm font-medium transition focus:outline-none focus:ring-2 focus:ring-accent-200', $presenter->isLinkCurrent('Category:*') ? 'bg-stone-100 text-stone-900' : 'text-stone-500 hover:bg-stone-50 hover:text-stone-900'"
				>Kategorie</a>
			</nav>
			{* Odhlášení mění stav → POST formulář (same-origin CSRF ochrana), viz SignPresenter::actionOut(). *}
			<form method="post" action="{link Sign:out}" class="ml-auto">
				<button type="submit" class="btn-ghost">Odhlásit se</button>
			</form>
		</div>
	</header>

	<div n:if="$flashes" class="mx-auto w-full max-w-3xl space-y-2 px-4 pt-4 sm:px-6">
		<p n:foreach="$flashes as $flash"
			n:class="'rounded-lg px-3 py-2 text-sm', $flash->type === 'error' ? 'bg-red-50 text-red-700' : 'bg-accent-50 text-accent-700'"
			n:attr="role => $flash->type === 'error' ? 'alert' : 'status'"
		>{$flash->message}</p>
	</div>

	<main class="mx-auto w-full max-w-3xl px-4 py-6 sm:px-6 sm:py-8">
		{include content}
	</main>
{else}
	{include content}
{/if}
</body>
</html>
