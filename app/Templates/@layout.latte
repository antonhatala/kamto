<!DOCTYPE html>
<html lang="cs">
<head>
	<meta charset="utf-8">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<title>{block title}Kamto{/block}</title>
	<meta name="theme-color" content="#ffffff">
	<link rel="stylesheet" href="/css/app.css">
	<link rel="manifest" href="/manifest.json">
	<link rel="icon" href="/icons/favicon.png" type="image/png">
	<link rel="apple-touch-icon" href="/icons/apple-touch-icon.png">
	<script src="/js/app.js" defer></script>
</head>
<body class="min-h-dvh bg-stone-50 font-sans text-stone-900 antialiased">
{if $user->isLoggedIn()}
	<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-lg focus:bg-white focus:px-4 focus:py-2 focus:text-sm focus:font-medium focus:text-stone-900 focus:shadow-md focus:ring-2 focus:ring-accent-300">Přeskočit na obsah</a>
	<header class="border-b border-stone-200 bg-white">
		<div class="mx-auto flex max-w-3xl flex-wrap items-center gap-x-2 gap-y-2 px-4 py-3 sm:flex-nowrap sm:px-6">
			<a n:href="Home:default" class="order-1 flex flex-col items-start gap-1 rounded-lg focus:outline-none focus:ring-2 focus:ring-accent-200">
				<span class="text-base font-bold leading-none tracking-tight text-accent-700">kamto</span>
				<span class="flex items-center gap-1" aria-hidden="true">
					<span class="h-1.5 w-1.5 rounded-full" style="background-color:#c1622e"></span>
					<span class="h-1.5 w-1.5 rounded-full" style="background-color:#188f77"></span>
					<span class="h-1.5 w-1.5 rounded-full" style="background-color:#c9972e"></span>
					<span class="h-1.5 w-1.5 rounded-full" style="background-color:#2168a3"></span>
					<span class="h-1.5 w-1.5 rounded-full border border-dashed" style="border-color:#dca277"></span>
				</span>
			</a>
			<nav aria-label="Hlavní navigace" class="order-3 w-full overflow-x-auto sm:order-2 sm:ml-2 sm:w-auto sm:overflow-visible">
				<div class="flex w-max items-center gap-1 sm:w-auto">
					<a n:href="Home:default"
						n:class="'rounded-lg px-3 py-1.5 text-sm font-medium transition focus:outline-none focus:ring-2 focus:ring-accent-200', $presenter->isLinkCurrent('Home:*') ? 'bg-stone-100 text-stone-900' : 'text-stone-500 hover:bg-stone-50 hover:text-stone-900'"
						n:attr="aria-current => $presenter->isLinkCurrent('Home:*') ? 'page' : null"
					>Co zaplatit</a>
					<a n:href="Overview:default"
						n:class="'rounded-lg px-3 py-1.5 text-sm font-medium transition focus:outline-none focus:ring-2 focus:ring-accent-200', $presenter->isLinkCurrent('Overview:*') ? 'bg-stone-100 text-stone-900' : 'text-stone-500 hover:bg-stone-50 hover:text-stone-900'"
						n:attr="aria-current => $presenter->isLinkCurrent('Overview:*') ? 'page' : null"
					>Přehledy</a>
					<a n:href="Service:default"
						n:class="'rounded-lg px-3 py-1.5 text-sm font-medium transition focus:outline-none focus:ring-2 focus:ring-accent-200', $presenter->isLinkCurrent('Service:*') ? 'bg-stone-100 text-stone-900' : 'text-stone-500 hover:bg-stone-50 hover:text-stone-900'"
						n:attr="aria-current => $presenter->isLinkCurrent('Service:*') ? 'page' : null"
					>Služby</a>
					<a n:href="Category:default"
						n:class="'rounded-lg px-3 py-1.5 text-sm font-medium transition focus:outline-none focus:ring-2 focus:ring-accent-200', $presenter->isLinkCurrent('Category:*') ? 'bg-stone-100 text-stone-900' : 'text-stone-500 hover:bg-stone-50 hover:text-stone-900'"
						n:attr="aria-current => $presenter->isLinkCurrent('Category:*') ? 'page' : null"
					>Kategorie</a>
				</div>
			</nav>
			<form method="post" action="{link Sign:out}" class="order-2 ml-auto sm:order-3">
				<button type="submit" class="btn-ghost">Odhlásit se</button>
			</form>
		</div>
	</header>

	<div n:if="$flashes" class="mx-auto w-full max-w-3xl space-y-2 px-4 pt-4 sm:px-6">
		<p n:foreach="$flashes as $flash"
			n:class="'rounded-lg px-3 py-2 text-sm', $flash->type === 'error' ? 'bg-red-50 text-red-700' : 'bg-accent-50 text-accent-700'"
			n:attr="role => $flash->type === 'error' ? 'alert' : 'status'"
		>{$flash->message}</p>
	</div>

	<main id="main-content" class="mx-auto w-full max-w-3xl px-4 py-6 sm:px-6 sm:py-8">
		{include content}
	</main>
{else}
	{include content}
{/if}
</body>
</html>
