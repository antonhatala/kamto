{
	"name": "anton.hatala/kamto",
	"description": "Kamto — evidence pravidelných plateb",
	"type": "project",
	"license": "proprietary",
	"require": {
		"php": "^8.5",
		"latte/latte": "^3.1",
		"nette/application": "^3.3",
		"nette/bootstrap": "^3.3",
		"nette/di": "^3.2",
		"nette/forms": "^3.3",
		"nette/http": "^3.4",
		"nette/robot-loader": "^4.1",
		"nette/security": "^3.2",
		"tracy/tracy": "^2.12"
	},
	"autoload": {
		"psr-4": {
			"App\\": "app/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"Tests\\": "tests/"
		}
	},
	"config": {
		"sort-packages": true
	},
	"minimum-stability": "stable",
	"prefer-stable": true,
	"require-dev": {
		"nette/tester": "^2.6",
		"phpstan/phpstan": "^2.2",
		"phpstan/phpstan-nette": "^2.0"
	},
	"scripts": {
		"phpstan": "phpstan analyse",
		"tester": "tester tests -s",
		"test": [
			"@phpstan",
			"@tester"
		]
	}
}
