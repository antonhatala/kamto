# Lokální tajnosti (gitignored + dockerignored). Zkopíruj do config.local.neon a dej sem
# svůj hash hesla. Vývojová override (vypnutí CSP pro Tracy) UŽ TU NENÍ — přesunuta do
# verzovaného config/config.dev.neon, které Bootstrap načte jen v debug módu. Tenhle soubor
# proto drží čistě jen tajnosti.
parameters:
	# Vygeneruj VLASTNÍ hash (v Dockeru, bez PHP na hostu):
	#   docker compose run --rm php php -r "echo password_hash('tvé-heslo', PASSWORD_DEFAULT), PHP_EOL;"
	# Hodnota níže je jen placeholder — NENÍ platný bcrypt hash, nahraď ho svým (jinak se nepřihlásíš).
	# (Záměrně tu není funkční hash — ať se do gitu nedostane reálná, byť localhost-only, credential.)
	appPasswordHash: 'REPLACE_ME_bcrypt_hash'
