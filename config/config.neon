parameters:
	# Bcrypt/argon hash of the login password. Locally overridden in config.local.neon,
	# on production supplied via the APP_PASSWORD_HASH environment variable.
	appPasswordHash: %env.APP_PASSWORD_HASH%

	# DB brána (Fáze 1) — lokální default je PdoSqliteDb nad var/kamto.db (%rootDir% =
	# projekt root, viz Nette\Bootstrap\Configurator). `url`/`token` je tvar připravený pro
	# LibsqlDb (nativní libSQL extension) — reálně zapojené (driver: libsql +
	# %env.DATABASE_URL%/%env.DATABASE_TOKEN%) až ve Fázi 6 (Bunny deploy).
	database:
		driver: pdo-sqlite
		path: %rootDir%/var/kamto.db
		url: ''
		token: ''

application:
	mapping: App\Presenters\*Presenter

latte:
	extensions:
		- App\Latte\MoneyExtension

http:
	headers:
		# Don't advertise the framework in responses.
		X-Powered-By: null
		# Baseline hardening (bezpečnostní review Fáze 2) — brání MIME sniffingu a omezuje únik
		# URL v Referer hlavičce mimo vlastní origin.
		X-Content-Type-Options: nosniff
		Referrer-Policy: same-origin
		# CSP (Fáze 5) — pragmatická, po externalizaci klientského JS do /js/app.js:
		#   script-src 'self'  → žádný inline <script> (to je ta výhra z externalizace).
		#   style-src 'unsafe-inline' → NUTNÉ kvůli inline `style="background-color:#hex"` u
		#     kategorií/heatmapy (hex je serverový whitelist, viz CategoryPresenter::Palette).
		#   img-src data: → povolené data URI obrázky. object-src 'none', base-uri/form-action 'self'.
		# ROZHODNUTÍ: CSP je PRODUKČNÍ. V dev režimu ji vypíná config.local.neon (Content-Security-Policy: null),
		# protože Tracy debug bar injektuje inline <script>+eval a striktní CSP by ho rozbila. config.local.neon
		# existuje jen lokálně (gitignored) → na Bunny se CSP reálně aplikuje. Viz CLAUDE.md „Bezpečnost".
		Content-Security-Policy: "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; object-src 'none'; base-uri 'self'; form-action 'self'; manifest-src 'self'"

services:
	router: App\Router\RouterFactory::createRouter
	authenticator: App\Security\SinglePasswordAuthenticator(%appPasswordHash%)
	database: App\Database\DbFactory::create(%database%)
	loginThrottle: App\Security\LoginThrottle(%tempDir%/login-throttle.json)
	- App\Forms\FormTranslator
	- App\Forms\FormFactory
	- App\Model\CategoryRepository
	- App\Model\ServiceRepository
	- App\Model\PaymentRepository
	- App\Support\SystemClock
	- App\Payment\PaymentService
